          </a>
        </div>
      </div>
    </article>

    <!-- EvaluaApp -->
    <article class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-200 transition-all overflow-hidden">
      <div class="w-full h-48 overflow-hidden relative group">
        <img 
          src="/projects/evaluaapp.jpeg" 
          alt="EvaluaApp" 
          class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="flex flex-col flex-1 p-6 space-y-3">
        <h3 class="text-xl font-bold text-slate-800">EvaluaApp</h3>
        <p class="text-slate-600 text-sm flex-1 leading-relaxed">
          Plataforma web para la gestión de evaluaciones académicas. Permite la creación de clases, carga de exámenes mediante Excel y gestión de rúbricas de coevaluación.
        </p>
        <ul class="flex flex-wrap gap-2">
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Java 17</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Node.js</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">MySQL</span></li>
        </ul>
        <div class="pt-4 border-t border-slate-100">
          <a href="https://github.com/jhuertasn/tesis-sistema-rubricas" target="_blank"
            class="inline-flex items-center gap-2 bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-slate-700 transition">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
