---
---
<section id="proyectos" class="py-16 max-w-4xl mx-auto">
  <h2 class="text-3xl font-bold mb-8 text-slate-900 flex items-center gap-3">
    <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
    </svg>
    Proyectos Recientes
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- Comparador de Precios -->
    <article class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-200 transition-all overflow-hidden">
      <div class="w-full h-48 overflow-hidden relative group">
        <img 
          src="/projects/comparador-precios.jpeg" 
          alt="Comparador de Precios" 
          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="flex flex-col flex-1 p-6 space-y-3">
        <h3 class="text-xl font-bold text-slate-800">Comparador de Precios</h3>
        <p class="text-slate-600 text-sm flex-1 leading-relaxed">
          Extensión de Chrome con Web Scraping para comparar precios en tiempo real entre Falabella y Mercado Libre. Incluye dashboard con análisis estadístico, detección de outliers y gráficos comparativos.
        </p>
        <ul class="flex flex-wrap gap-2">
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">TypeScript</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Vite</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Chart.js</span></li>
        </ul>
        <div class="pt-4 border-t border-slate-100">
          <a href="https://github.com/jhuertasn/krowdy-reto1-comparador-precios" target="_blank"
            class="inline-flex items-center gap-2 bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-slate-700 transition">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
            </svg>
            Ver código
          </a>
        </div>
      </div>
    </article>

    <!-- EcoPoints -->
    <article class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-200 transition-all overflow-hidden">
      <div class="w-full h-48 overflow-hidden relative group">
        <img 
          src="/projects/ecopoints.jpeg" 
          alt="EcoPoints" 
          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="flex flex-col flex-1 p-6 space-y-3">
        <h3 class="text-xl font-bold text-slate-800">EcoPoints – Plataforma de Reciclaje</h3>
        <p class="text-slate-600 text-sm flex-1 leading-relaxed">
          Arquitectura de microservicios orientada a eventos para gestionar el ciclo de vida del reciclaje. Sistema desacoplado y asíncrono para garantizar escalabilidad en tiempo real.
        </p>
        <ul class="flex flex-wrap gap-2">
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">React</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Spring Boot</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Docker</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">RabbitMQ</span></li>
        </ul>
        <div class="pt-4 border-t border-slate-100">
          <a href="https://github.com/jhuertasn/proyecto-ecopoints" target="_blank"
            class="inline-flex items-center gap-2 bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-slate-700 transition">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
            </svg>
