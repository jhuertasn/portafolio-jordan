    </article>

    <!-- Reproductor Inteligente -->
    <article class="flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-200 transition-all overflow-hidden">
      <div class="w-full h-48 overflow-hidden relative group">
        <img 
          src="/projects/reproductor-video.jpeg" 
          alt="Reproductor Inteligente de Video" 
          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
        />
      </div>
      <div class="flex flex-col flex-1 p-6 space-y-3">
        <h3 class="text-xl font-bold text-slate-800">Reproductor Inteligente de Video</h3>
        <p class="text-slate-600 text-sm flex-1 leading-relaxed">
          Reproductor avanzado para análisis de entrevistas con etiquetas temporales dinámicas y salto automático de intervalos irrelevantes mediante tiempo virtual.
        </p>
        <ul class="flex flex-wrap gap-2">
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">React</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">Custom Hooks</span></li>
          <li><span class="bg-indigo-50 text-indigo-700 border border-indigo-100 text-xs font-semibold px-2.5 py-1 rounded-full">JavaScript</span></li>
        </ul>
        <div class="pt-4 border-t border-slate-100">
          <a href="https://github.com/jhuertasn/Reto-2-reproductor-entrevista-krowdy2026" target="_blank"
            class="inline-flex items-center gap-2 bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-slate-700 transition">
