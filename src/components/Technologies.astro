---
---
<section id="mi-stack" class="py-16">
  <h2 class="text-3xl font-bold mb-8 text-slate-200">Tecnologías</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <article class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
      <h3 class="text-xl font-bold text-blue-600 mb-6 text-center">Frontend</h3>
      <div class="grid grid-cols-3 gap-y-6 gap-x-4 text-center">
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">HTML</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">CSS</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">JavaScript</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Tailwind</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Astro</span></div>
      </div>
    </article>

    <article class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
      <h3 class="text-xl font-bold text-blue-600 mb-6 text-center">Soporte & Herramientas</h3>
      <div class="grid grid-cols-3 gap-y-6 gap-x-4 text-center">
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Linux</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Windows Server</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Python</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">Git</span></div>
        <div class="flex flex-col items-center gap-2"><div class="w-12 h-12 bg-slate-100 rounded-xl"></div><span class="text-sm font-medium text-slate-700">GitHub</span></div>
      </div>
    </article>

  </div>
</section>